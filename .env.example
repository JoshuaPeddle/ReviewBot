# Copy this file to .env and fill in the values, then `docker compose up`.

# --- GitHub App credentials (required) ---
# Numeric App ID from your GitHub App's "General" settings page.
REVIEWBOT_APP_ID=12345

# Private key PEM contents on a single line. From a downloaded *.pem file:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' your-app.private-key.pem
REVIEWBOT_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n

# Webhook secret you configured in the GitHub App settings.
REVIEWBOT_WEBHOOK_SECRET=change-me

# Optional: bot account login (e.g. "reviewbot[bot]"). Used to filter out the
# bot's own comments from /review trigger detection.
REVIEWBOT_BOT_SLUG=

# --- Model selection ---
# Reference profile: qwen/qwen3.6-27b at 72K context.
#   Needs ~17GB pull, a 24GB NVIDIA card (3090/4090/A5000) or a 32GB+ M-series
#   Mac with unified memory. This is the model the eval gate is measured against.
#
# Fallback for 8–16GB GPUs / tighter machines (lower quality):
#   qwen2.5:7b-instruct-q4_K_M       # ~5GB, 32K context
#   llama3.1:8b-instruct-q4_K_M      # ~5GB, 8K context
#
# If your Ollama registry can't resolve "qwen/qwen3.6-27b", swap to a tag it
# can pull, or run the model via LM Studio / vLLM and point
# REVIEWBOT__OpenAi__BaseUrl at that endpoint instead (see docker-compose.yml).
REVIEWBOT_MODEL_NAME=qwen/qwen3.6-27b
