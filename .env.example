# Copy this file to .env and fill in the values, then `docker compose up`.

# --- GitHub App credentials (required) ---
# Numeric App ID from your GitHub App's "General" settings page.
REVIEWBOT_APP_ID=12345

# Private key PEM contents on a single line. From a downloaded *.pem file:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' your-app.private-key.pem
REVIEWBOT_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n

# Webhook secret you configured in the GitHub App settings.
REVIEWBOT_WEBHOOK_SECRET=change-me

# Optional: bot account login (e.g. "reviewbot[bot]"). Used to filter out the
# bot's own comments from /review trigger detection.
REVIEWBOT_BOT_SLUG=

# --- Model selection ---
# Any Ollama model tag. The model-puller service pulls this on first start.
# Recommended for 16GB+ RAM: qwen2.5:7b-instruct-q4_K_M (~5GB, 32K context).
# For tighter machines: llama3.1:8b-instruct-q4_K_M (~5GB, 8K context).
REVIEWBOT_MODEL_NAME=qwen2.5:7b-instruct-q4_K_M
