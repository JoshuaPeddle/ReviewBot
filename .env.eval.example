# Copy to .env.eval (gitignored) and adjust for your local LLM server.
# Loaded automatically by the Makefile via `include .env.eval`.
# Used by: make eval-probe, make eval-live-baseline, make eval-live-retrieval,
# make eval-live-compare.

# Base URL of the OpenAI-compatible endpoint serving the reference model.
# LM Studio on the LAN box hosting qwen/qwen3.6-27b (default port :1234):
REVIEWBOT_EVAL_BASE_URL=http://192.168.2.167:1234/v1

# Reference model name as the server exposes it.
REVIEWBOT_EVAL_MODEL_NAME=qwen/qwen3.6-27b

# API key value sent to the OpenAI client. Ollama ignores the value but the
# SDK requires it to be non-empty. Most local servers will accept anything.
REVIEWBOT_EVAL_OPENAI_API_KEY=ollama

# Model context window we tell the worker we have available. Pick something
# at or under your model's true limit; qwen/qwen3.6-27b advertises 72K.
REVIEWBOT_EVAL_CONTEXT_TOKENS=65536
