{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
    "Webhook": {
        "Secret": "",
        "BotSlug": ""
    },
    "GitHubApp": {
        "AppId": 0,
        "PrivateKeyPem": "",
        "ApiBaseUrl": "https://api.github.com/"
    },
    "Anthropic": {
        "ApiKey": "",
        "ModelName": "claude-opus-4-7",
        "MaxTokens": 4096,
